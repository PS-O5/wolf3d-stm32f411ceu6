# -----------------------------------------------------------------------------
# C/C++ Build Outputs
# -----------------------------------------------------------------------------
# Ignore CMake generated folders and build artifacts
build/
out/
bin/
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.dylib

# Simulator Executables (Windows/Linux/Mac)
*.exe
*.out
*.app

# STM32 Bare-Metal Binaries
*.elf
*.bin
*.hex
*.map

# -----------------------------------------------------------------------------
# Python Asset Extractor Outputs
# -----------------------------------------------------------------------------
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/

# Ignore the debug PNGs generated for sprite verification
sprites_png/

